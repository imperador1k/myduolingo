{
  "$schema": "../gen/schemas/desktop-capability.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:allow-minimize",
    "core:window:allow-close",
    "core:window:allow-set-focus"
  ]
}
