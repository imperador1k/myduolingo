# 🦉 MYDUOLINGO - ENVIRONMENT VARIABLES EXAMPLE
# Copy this file to .env and fill in the values.

# 🌐 GENERAL APP SETTINGS
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 🗄️ DATABASE (Supabase / PostgreSQL)
# Get your connection string from Supabase project settings.
DATABASE_URL="postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:6543/postgres"

# 🔐 AUTHENTICATION (Clerk)
# Available at https://dashboard.clerk.com/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/auth-success
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/auth-success

# ⚡ SUPABASE (Client & Edge Functions)
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_ID].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# 🤖 AI & LLM (Google Gemini)
# Generate your key at https://aistudio.google.com/
GEMINI_API_KEY=AIzaSy...

# 📺 EXTERNAL INTEGRATIONS (Giphy & Google)
NEXT_PUBLIC_GIPHY_API_KEY=...
GOOGLE_CLIENT_ID=...-tl482bhrivvbni5idpuhb1hkbasjturj.apps.googleusercontent.com

# 🔔 NOTIFICATIONS (OneSignal)
# Setup at https://onesignal.com/
ONESIGNAL_APP_ID=...
ONESIGNAL_REST_API_KEY=...

# 🛡️ SECURITY & RATE LIMITING (Upstash Redis)
# Needed for @upstash/ratelimit
UPSTASH_REDIS_REST_URL=https://...-81312.upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# 🩺 OBSERVABILITY (Sentry)
# Generate a token in your Sentry organization settings.
SENTRY_AUTH_TOKEN=sntrys_...


RESEND_API_KEY=re_...
SUPPORT_EMAIL=youremail@gmail.com
